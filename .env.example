# Root environment example — used by docker-compose.yml.
# Copy to .env and adjust. Never commit real secrets.
#
# Per-app development examples live at:
#   apps/api/.env.example        (FastAPI service settings)
#   apps/web/.env.local.example  (frontend API base URL)
# Deployment examples live under docs/deployment/env/.

# PostgreSQL password for the compose database (dev default is fine locally).
POSTGRES_PASSWORD=airspacesim-dev

# Where the browser reaches the API (compose publishes it on 8000).
VITE_API_BASE_URL=http://127.0.0.1:8000

# API behaviour
AIRSPACESIM_API_ENVIRONMENT=development
AIRSPACESIM_API_LOG_LEVEL=INFO
AIRSPACESIM_API_ANONYMOUS_RUN_RETENTION_DAYS=14
