# AirSpaceSim API production environment.
#
# Replace hostnames and database path before use.

AIRSPACESIM_API_APP_NAME=AirSpaceSim API
AIRSPACESIM_API_API_V1_PREFIX=/api/v1
AIRSPACESIM_API_DATABASE_URL=sqlite:////srv/airspacesim/airspacesim-api.db
AIRSPACESIM_API_DATABASE_ECHO=false
AIRSPACESIM_API_AUTO_CREATE_SCHEMA=false
AIRSPACESIM_API_CHECKPOINT_RETENTION_PER_RUN=25
AIRSPACESIM_API_CORS_ALLOWED_ORIGINS=["https://airspacesim.example.com"]
AIRSPACESIM_API_CORS_ALLOW_CREDENTIALS=false
AIRSPACESIM_API_DEBUG=false
AIRSPACESIM_API_ENVIRONMENT=production
